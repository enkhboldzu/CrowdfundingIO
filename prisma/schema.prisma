generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ProjectStatus {
  PENDING
  ACTIVE
  REJECTED
  FUNDED
  FAILED
  CANCELLED
}

model User {
  id         String    @id @default(cuid())
  name       String
  email      String?   @unique
  phone      String?   @unique
  password   String
  role       Role      @default(USER)
  avatar     String?
  isVerified Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  projects  Project[]
  donations Donation[]

  @@index([email])
  @@index([phone])
}

model Project {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String        @db.Text
  category        String
  goal            Float
  raised          Float         @default(0)
  backers         Int           @default(0)
  location        String        @default("")
  status          ProjectStatus @default(PENDING)
  isVerified      Boolean       @default(false)
  isTrending      Boolean       @default(false)
  isFeatured      Boolean       @default(false)
  coverImage      String?
  isPublished     Boolean       @default(false)
  endsAt          DateTime
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  donations   Donation[]
  rewardTiers RewardTier[]
  updates     FundingUpdate[]

  @@index([status])
  @@index([category])
  @@index([isTrending])
  @@index([isFeatured])
  @@index([creatorId])
}

model Donation {
  id        String   @id @default(cuid())
  amount    Float
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rewardTierId String?
  rewardTier   RewardTier? @relation(fields: [rewardTierId], references: [id])

  @@index([projectId])
  @@index([userId])
}

model RewardTier {
  id                String   @id @default(cuid())
  title             String
  description       String   @db.Text
  amount            Float
  isLimited         Boolean  @default(false)
  remaining         Int?
  backerCount       Int      @default(0)
  estimatedDelivery String
  createdAt         DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  donations Donation[]

  @@index([projectId])
}

model FundingUpdate {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
