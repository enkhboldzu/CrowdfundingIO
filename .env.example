# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL recommended)
DATABASE_URL="postgresql://user:password@localhost:5432/crowdfund_mn"

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# Next.js frontend public URL, used by the Google OAuth callback URL
APP_URL=https://crowdfunding.bowsys.mn

# QPay merchant API
# Production: https://merchant.qpay.mn
# Sandbox:    https://merchant-sandbox.qpay.mn
QPAY_BASE_URL=https://merchant.qpay.mn
QPAY_MERCHANT_USERNAME=
QPAY_MERCHANT_PASSWORD=
QPAY_INVOICE_CODE=
# Backward-compatible aliases also work:
# QPAY_CLIENT_ID=
# QPAY_CLIENT_SECRET=

# Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI AI chatbot
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# CORS - comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# File uploads (optional - use cloud storage in production)
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
